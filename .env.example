# RemnaWave subscription URL (passed to xray-checker)
SUBSCRIPTION_URL=https://your-remnawave-instance/sub/YOUR_TOKEN_HERE

# Basic auth credentials for xray-checker's /api/ endpoints
XRAY_CHECKER_USER=admin
XRAY_CHECKER_PASS=change_me_to_a_strong_password

# Internal URL of xray-checker (used server-side by Next.js)
# In Docker: http://xray-checker:2112
# Locally: http://localhost:2112
XRAY_CHECKER_URL=http://xray-checker:2112
